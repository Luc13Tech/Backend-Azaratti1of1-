# =====================================================
#  EMPLACEMENTS À REMPLIR — Variables d'environnement
#  Copie ce fichier en ".env" (jamais commit sur GitHub)
#  et remplis chaque valeur. Sur Render, ajoute ces
#  mêmes variables dans Dashboard > Environment.
# =====================================================

# Port (Render le définit automatiquement, garde 5000 en local)
PORT=5000

# MongoDB Atlas — Database > Connect > Drivers, copie l'URI et remplace <password>
MONGODB_URI=REMPLACER_PAR_TON_URI_MONGODB_ATLAS

# JWT — génère une chaîne aléatoire longue et secrète (ex: openssl rand -base64 48)
JWT_SECRET=REMPLACER_PAR_UNE_CHAINE_SECRETE_LONGUE
JWT_EXPIRES_IN=7d

# URL du frontend Vercel (pour configurer CORS correctement)
FRONTEND_URL=https://REMPLACER.vercel.app

# Email (Nodemailer via Gmail) — utiliser un "mot de passe d'application" Google,
# pas le mot de passe du compte. Génère-le sur https://myaccount.google.com/apppasswords
EMAIL_USER=azarattiof@gmail.com
EMAIL_APP_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_APPLICATION_GMAIL

# WhatsApp (utilisé uniquement côté frontend, gardé ici pour référence)
WHATSAPP_NUMBER=229779398484
